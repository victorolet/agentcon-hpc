# Foundry project connection string. Find under "Project details" in
# Azure AI Foundry portal. Format:
#   <region>.api.azureml.ms;<sub-id>;<rg>;<project>
PROJECT_CONNECTION_STRING=https://victorolet-1758-resource.services.ai.azure.com/api/projects/victorolet-1758

# Name of the chat model deployment inside that Foundry project.
# (You deploy gpt-4o or gpt-4.1 in the Foundry portal; the deployment
# name is what you pick there, e.g. "gpt-4o".)
MODEL_DEPLOYMENT_NAME=gpt-4o

# Where simulation runs are stored on the VM.
DATA_DIR=/data

# Path to this repo's workflow/ dir. Used by tools.py to invoke shell scripts.
WORKFLOW_DIR=/home/azureuser/agentcon-hpc-demo/workflow

# Container tag the agent expects. Match this to the image you built:
#   gromacs-demo:cuda   (Dockerfile)
#   gromacs-demo:rocm   (Dockerfile.rocm)
#   gromacs-demo:cpu    (Dockerfile.cpu)
GMX_IMAGE=gromacs-demo:rocm

# GPU vendor — controls docker run flags and mdrun GPU offload.
#   nvidia (default historical) -> --gpus all
#   amd                          -> --device=/dev/kfd ... (ROCm)
#   cpu                          -> no GPU flags, mdrun stays on CPU
# Your subscription's NV*as_v4 quota points you at "amd". If ROCm can't
# see the GPU on that VM family, switch this to "cpu" — see docs/gpu-vendors.md.
GPU_VENDOR=amd
